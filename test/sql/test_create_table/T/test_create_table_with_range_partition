-- name: test_create_range_partition_table_smallint
create database db_${uuid0};
use db_${uuid0};

CREATE TABLE t_range_null_smallint (
    k SMALLINT,
    v INT
) ENGINE=OLAP
DUPLICATE KEY(k)
PARTITION BY RANGE(k) (
    PARTITION p1 VALUES LESS THAN ('-3200'),
    PARTITION p2 VALUES LESS THAN ('0'),
    PARTITION p3 VALUES LESS THAN ('32000')
)
DISTRIBUTED BY HASH(k) BUCKETS 1
PROPERTIES ("replication_num" = "1");

INSERT INTO t_range_null_smallint VALUES (-5000, 1), (-100, 2), (0, 3), (100, 4), (31000, 5);
SELECT * FROM t_range_null_smallint ORDER BY k;

[UC]SHOW PARTITIONS FROM t_range_null_smallint;

SELECT * FROM t_range_null_smallint PARTITION(p1) ORDER BY k;
SELECT * FROM t_range_null_smallint PARTITION(p2) ORDER BY k;
SELECT * FROM t_range_null_smallint PARTITION(p3) ORDER BY k;

-- test NULL value insert into range partition
INSERT INTO t_range_null_smallint VALUES (NULL, 6);

drop table t_range_null_smallint;

-- name: test_create_range_partition_table_int
use db_${uuid0};

CREATE TABLE t_range_int (
    k INT,
    v INT
) ENGINE=OLAP
DUPLICATE KEY(k)
PARTITION BY RANGE(k) (
    PARTITION p1 VALUES LESS THAN ('-100'),
    PARTITION p2 VALUES LESS THAN ('0'),
    PARTITION p3 VALUES LESS THAN ('100'),
    PARTITION p4 VALUES LESS THAN ('1000')
)
DISTRIBUTED BY HASH(k) BUCKETS 1
PROPERTIES ("replication_num" = "1");

INSERT INTO t_range_int VALUES (-200, 1), (-50, 2), (0, 3), (50, 4), (500, 5);
SELECT * FROM t_range_int ORDER BY k;

SELECT * FROM t_range_int PARTITION(p1) ORDER BY k;
SELECT * FROM t_range_int PARTITION(p2) ORDER BY k;
SELECT * FROM t_range_int PARTITION(p3) ORDER BY k;
SELECT * FROM t_range_int PARTITION(p4) ORDER BY k;

drop table t_range_int;

